# Example .env configuration for Shiprocket Webhook Handler

# Shiprocket Webhook Configuration
# Use a strong, random token in production
SHIPROCKET_API_KEY=mysecret123

# Example of a strong token (generate your own):
# SHIPROCKET_API_KEY=sk_live_4eC39HqLyjWDarhtT8AQkGvK7EnQR1qC

# Alternative: Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
